{
  "ci": {
    "collect": {
      "staticDistDir": "web/dist",
      "numberOfRuns": 3,
      "settings": { "chromeFlags": "--no-sandbox" }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.78 }],
        "categories:best-practices": ["error", { "minScore": 0.85 }],
        "categories:performance": ["warn", { "minScore": 0.7 }],
        "categories:seo": "off"
      }
    }
  }
}
